# Copy this file to .env and fill in your values. .env is gitignored.
# Loaded automatically on startup (db.py uses python-dotenv).

# --- LLM endpoint (ADR 0002: local by default, hosted opt-in) ----------------
# Omit all three to use the local Ollama default (base http://localhost:11434/v1,
# model phi4-mini). Set them to run on a hosted OpenAI-compatible provider:

# Groq example:
# CITEFINDER_LLM_BASE_URL=https://api.groq.com/openai/v1
# CITEFINDER_LLM_KEY=gsk_your_key_here
# CITEFINDER_LLM_MODEL=llama-3.3-70b-versatile

# --- Database (optional) -----------------------------------------------------
# Defaults to the local Docker Postgres; override only to point elsewhere.
# CITEFINDER_DB=host=localhost dbname=citefinder user=postgres password=devpass
